{
  "name": "dreamhack-local-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-only dashboard UI for the DreamHack Local backend.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
